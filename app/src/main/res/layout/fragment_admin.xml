<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Access Restricted Message (hidden by default, shown for non-admins) -->
    <TextView
        android:id="@+id/tv_access_restricted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Acceso restringido para administradores"
        android:textColor="@color/admin_label"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Admin Content Container -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/admin_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Header Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PANEL ADMINISTRATIVO"
                android:textColor="@color/admin_label"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manejo\nde Recursos"
                android:textColor="@color/on_surface"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:lineSpacingMultiplier="1.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mira, configura, y mantiene los recursos de aprendizaje guardados en la aplicación."
                android:textColor="@color/admin_header_subtitle"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="20dp" />

            <Button
                android:id="@+id/btn_admin_create_resource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crear nuevo recurso"
                android:layout_marginBottom="12dp"
                app:cornerRadius="8dp" />

            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/admin_search_bg"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/pagination_text"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/et_admin_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Buscar recursos..."
                    android:textColorHint="@color/pagination_text"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Filter Chips Row -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_admin_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_outline_bg"
                        android:backgroundTint="@color/primary_light"
                        android:text="Todos"
                        android:textColor="@color/chip_text"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/chip_admin_books"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_outline_bg"
                        android:backgroundTint="@color/chip_bg"
                        android:text="Libros"
                        android:textColor="@color/chip_text"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/chip_admin_videos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_outline_bg"
                        android:backgroundTint="@color/chip_bg"
                        android:text="Videos"
                        android:textColor="@color/chip_text"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/chip_admin_articles"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_outline_bg"
                        android:backgroundTint="@color/chip_bg"
                        android:text="Articulos"
                        android:textColor="@color/chip_text"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/chip_admin_courses"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_outline_bg"
                        android:backgroundTint="@color/chip_bg"
                        android:text="Cursos"
                        android:textColor="@color/chip_text"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:fontFamily="monospace"
                        android:textSize="13sp" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progress_admin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="@color/primary"
                android:visibility="gone" />

            <!-- Resources RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_admin_resources"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                tools:listitem="@layout/item_admin_resource" />

            <!-- Pagination Controls -->
            <LinearLayout
                android:id="@+id/pagination_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="16dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_pagination_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/pagination_text"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    tools:text="VIEWING 1-4 OF 2,472" />

                <ImageView
                    android:id="@+id/btn_prev_page"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="@color/pagination_text"
                    android:background="@drawable/chip_outline_bg"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:id="@+id/btn_next_page"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="@color/pagination_text"
                    android:background="@drawable/chip_outline_bg" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
