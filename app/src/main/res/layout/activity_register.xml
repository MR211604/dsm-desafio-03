<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">
    <!-- Main Card View -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/registerCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="12dp"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEMS_ENG"
                android:textColor="@color/primary"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Registrar nuevo acceso"
                android:textColor="@color/on_surface"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Crea tus credenciales para acceder a nuestro sistema de recursos."
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp" />

            <!-- Username Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Alias (Nombre de usuario)"
                android:textColor="@color/on_surface"
                android:fontFamily="monospace"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_bg"
                android:hint="admin_user"
                android:paddingHorizontal="16dp"
                android:textColorHint="@color/on_surface_variant"
                android:textColor="@color/on_surface"
                android:inputType="text" />

            <!-- Email Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Identificación (Email)"
                android:textColor="@color/on_surface"
                android:fontFamily="monospace"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_bg"
                android:hint="user@eng.systems"
                android:paddingHorizontal="16dp"
                android:textColorHint="@color/on_surface_variant"
                android:textColor="@color/on_surface"
                android:inputType="textEmailAddress" />

            <!-- Password Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="LLave de seguridad (contraseña)"
                android:textColor="@color/on_surface"
                android:fontFamily="monospace"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_bg"
                android:hint="••••••••••••"
                android:paddingHorizontal="16dp"
                android:textColorHint="@color/on_surface_variant"
                android:textColor="@color/on_surface"
                android:inputType="textPassword" />

            <!-- Register Button -->
            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/primary"
                android:text="REGISTRAR SESIÓN"
                android:fontFamily="monospace"
                android:textColor="@color/on_primary"
                android:textAllCaps="true"
                app:cornerRadius="4dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvGoToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="¿Ya tienes una cuenta? Inicia sesión aquí"
        android:textColor="@color/primary"
        android:fontFamily="monospace"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/registerCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>
